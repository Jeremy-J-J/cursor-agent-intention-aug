import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

extend top.main:
    # Y型路口合并场景定义
    curvature: road_curvature with:
        keep(curvature.direction == right_curve)

    road_straight: roads_follow_in_junction with:
        keep(it.internal_road.junction_category == merge)

    road_curvature: roads_follow_in_junction with:
        keep(it.internal_road.junction_category == merge)

    keep(road_curvature.in_road.id != road_straight.in_road.id)
    keep(road_straight.internal_road.junction_id == road_curvature.internal_road.junction_id)
    keep(road_straight.out_road.id == road_straight.out_road.id)

    roads_enter_junction_relation(road_curvature.in_road, 
                                  road_straight.in_road,
                                  relative_direction: any_left)

    conflicting_internal_road: internal_road_with_conflict
    keep(conflicting_internal_road.internal_road_id == road_curvature.internal_road.id)

    # NPC车辆
    npc_car_front: vehicle
    npc_car_rear: vehicle

    # 场景参数
    test_speed: speed with:
        keep(test_speed in [20kph..80kph])

    lane_ego: int with:
        keep(lane_ego > 1)

    do serial():
        # 阶段1：接近路口
        sut_approach: parallel():
            # 自车：沿弯道行驶，进入路口内部道路
            serial():
                sut_drive_pre: sut.car.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(curvature)

                sut_drive: sut.car.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(road_curvature.in_road, at: start)
                    along(road_curvature.internal_road, at: end)

            # 后车：在直行道路上行驶
            npc_car_rear.drive() with:
                along(road_straight.in_road, at: start)
                keep_lane()
                keep_speed(run_mode: best_effort)

            # 前车：在直行道路上行驶，位于后车前方
            npc_car_front.drive() with:
                speed(test_speed, at: start, run_mode: best_effort)
                position([20m..100m], ahead_of: npc_car_rear, at: start)
                keep_lane()
                keep_speed(run_mode: best_effort)

        # 阶段2：合并到出口道路
        sut_approach_merge: parallel():
            # 自车：从冲突道路合并到出口道路，并变道到最左侧车道
            sut_drive_merge: sut.car.drive() with:
                speed(test_speed, at: start, run_mode: best_effort)
                lane(lane_ego, at: start)
                lane(1, at: end)
                along(conflicting_internal_road, at: start)
                along(road_curvature.out_road, at: end)

            # 后车：从冲突道路的冲突道路合并到直行出口道路
            npc_car_rear.drive() with:
                speed(test_speed, at: start, run_mode: best_effort)
                lane(lane_ego, at: end)
                along(conflicting_internal_road.conflicting_road, at: start)
                along(road_straight.out_road, at: end)
                keep_speed(run_mode: best_effort)

            # 前车：在直行出口道路上行驶
            npc_car_front.drive() with:
                speed(test_speed, at: start, run_mode: best_effort)
                lane(lane_ego, at: end)
                along(road_straight.out_road, at: end)
                keep_speed(run_mode: best_effort)

