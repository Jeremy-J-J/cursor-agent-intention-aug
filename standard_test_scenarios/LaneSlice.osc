# 测试场景: 车道切片
# 描述: 测试前方有低速车且侧方有车辆切入时的应对(车道变窄效果)
# 场景: 自车以60kph行驶,前方20米处有30kph低速车,侧方有40kph车辆切入

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_cut_in_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.lane_slice_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "lane_slice_test_run")
    
    # 测试道路
    my_road: one_way_road
    
    # 自车车道
    ego_lane: int with:
        keep(it >= 1)
    
    # NPC切入起始车道
    npc_cut_in_lane: int with:
        keep(default it == ego_lane - 1)
    
    # 起始偏移
    start_offset: length with:
        keep(it <= my_road.length - 300m)
    
    # 自车速度
    ego_speed: speed with:
        keep(default it == 60kph)
    
    # 切入车辆速度
    cut_in_speed: speed with:
        keep(default it == 40kph)
    
    # 前方低速车速度
    lead_car_speed: speed with:
        keep(default it == 30kph)
    
    # 前方低速车距离
    lead_car_distance: length with:
        keep(it in [30m..50m])
    
    # 切入车辆相对位置
    cut_in_relative_position: length with:
        keep(it in [10m..20m])
    
    # 变道开始时间
    lane_change_start_time: time with:
        keep(default it in [0s..1s])
    
    # 变道持续时间
    lane_change_duration: time with:
        keep(default it in [0s..5s])
    
    # 测试持续时间
    duration_time: time with:
        keep(it >= lane_change_start_time + lane_change_duration + 10s)
    
    keep(sut.car.ftx_driver.bypass_behavior.allow_opposite_left_side == true)
    
    on @set_up.start:
        call logger.log_info("ego_speed: $(ego_speed)")
        call logger.log_info("cut_in_speed: $(cut_in_speed)")
        call logger.log_info("lead_car_speed: $(lead_car_speed)")
        call logger.log_info("lead_car_distance: $(lead_car_distance)")
        call logger.log_info("cut_in_relative_position: $(cut_in_relative_position)")
        call logger.log_info("lane_change_start_time: $(lane_change_start_time)")
        call logger.log_info("lane_change_duration: $(lane_change_duration)")
        call logger.log_info("duration_time: $(duration_time)")
    
    do serial():
        set_up: parallel():
            # 自车自由行驶
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_one_way_road() with:
                keep(it.gen_ego_speed_at_start == ego_speed)
                keep(it.ego_road_element == my_road)
                keep(it.gen_min_lanes == 2)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.ego_start_offset == start_offset)
                keep(it.ego_driving_duration == duration_time)
            
            # 前方低速车辆
            lead_car_phase: sut.npc_free_driving() with:
                keep(it.npc_relative_position == lead_car_distance)
                keep(it.npc_initial_speed == lead_car_speed)
                keep(it.npc_target_speed == lead_car_speed)
                keep(it.npc_initial_lane == npc_cut_in_lane)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 侧方切入车辆
            npc_cut_in_phase: sut.npc_cut_in() with:
                keep(it.npc_relative_position == cut_in_relative_position)
                keep(it.npc_initial_speed == cut_in_speed)
                keep(it.npc_target_speed == cut_in_speed)
                keep(it.npc_initial_lane == npc_cut_in_lane)
                keep(it.npc_target_lane == ego_lane)
                keep(it.npc_cut_in_start_time == lane_change_start_time)
                keep(it.npc_cut_in_duration == lane_change_duration)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.lane_slice_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "lane_slice_test_run"
    set additional_parameters.test_index = "auto_20251128_000000"
