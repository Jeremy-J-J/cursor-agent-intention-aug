import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M781_FTX_Roundabout_4_Legs.xodr"

extend top.main:
    # 环岛出口场景定义
    round_entry: roundabout_entry
    round_exit: roundabout_exit
    round_whole: roundabout_from_entry
    in_road: one_way_road
    out_road: one_way_road
    internal_road_round: internal_road
    internal_road_exit: internal_road

    keep(internal_road_round.in_one_way_road_id == in_road.id)
    keep(internal_road_exit.in_one_way_road_id == in_road.id)

    # NPC车辆
    npc_car_front: vehicle
    npc_car_rear: vehicle

    # 场景参数
    test_speed: speed with:
        keep(test_speed in [20kph..80kph])

    ego_offset: length

    npc_f_offset: length with:
        keep(it in [ego_offset+10m..ego_offset+50m])
        keep(it < internal_road_round.length - 10m)

    npc_r_offset: length with:
        keep(it in [10m-ego_offset..50m-ego_offset])
        keep(it <= in_road.length - 5m)
        keep(it > 0m)

    # 行为配置
    keep(sut.car.ftx_driver.bypass_behavior.enable == true)

    # 日志输出
    on @sut_to.start:
        call logger.log_info("round_entry.id: $(round_entry.id)") 
        call logger.log_info("internal_road_exit.id: $(internal_road_exit.id)") 
        call logger.log_info("internal_road_round.id: $(internal_road_round.id)") 
        call logger.log_info("in_road.id: $(in_road.id)")

    do serial():
        sut_to: parallel():
            # 自车：从环岛出口驶出
            serial():
                phase1: sut.car.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(round_exit, at: start, start_offset: ego_offset) 
                    along(internal_road_exit, at: start, run_mode: best_effort)
                    along(out_road, at: end, run_mode: best_effort)
                    lane(rightmost: true)

            # 后车：从入口道路进入环岛内部道路
            serial():
                npc_car_rear.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(in_road, at: start, end_offset: npc_r_offset)
                    along(internal_road_round, at: end, run_mode: best_effort)
                    lane(rightmost: true)
                    keep_speed()

            # 前车：在环岛内部道路上行驶
            serial():
                npc_car_front.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    lane(rightmost: true)
                    along(internal_road_round, at: start, start_offset: npc_f_offset)
                    keep_speed()