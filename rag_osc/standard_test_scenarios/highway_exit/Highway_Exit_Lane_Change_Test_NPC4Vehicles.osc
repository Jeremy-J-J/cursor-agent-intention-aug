# 场景: NextLaneExit_test_run
# 描述: 高速公路出口场景，自车从内侧车道向出口车道变道，中间车道有多辆NPC车辆
# 地图: M56_FTX_highway_prague.xodr (高速公路)

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_highway_exit_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$FTX/packages/maps/M56_FTX_highway_prague.xodr"

scenario sut.NextLaneExit_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "NextLaneExit_test_run")
    
    my_road: highway_exit
    
    # 自车起始车道
    ego_lane: int with:
        keep(it >= 1)
    
    # 出口车道(自车目标车道)
    exit_lane: int with:
        keep(it == ego_lane + 2)
    
    # NPC车道(位于自车和出口车道之间)
    npc_lane: int with:
        keep(it == ego_lane + 1)
    
    # 场景持续时间
    driving_duration: time with:
        keep(it in [10s..25s])
    
    # NPC速度
    npc_speed: speed with:
        keep(default it == 70kph)

    do serial():
        set_up: parallel():
            # 自车高速驾驶并向出口车道变道
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_highway_exit() with:
                keep(it.gen_ego_speed_at_start == 80kph)
                keep(it.ego_road_element == my_road)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.gen_ego_lane_at_end == exit_lane)
                keep(it.ego_driving_duration == driving_duration)
            
            # 中间车道NPC 1 (后方)
            npc_traffic_1: sut.npc_free_driving() with:
                keep(it.npc_relative_position in [-120m..-80m])
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == npc_lane)
                keep(it.npc_target_lane == npc_lane)
                keep(it.npc_duration == driving_duration)
                keep(it.ref_car == sut.car)
            
            # 中间车道NPC 2 (与自车平行)
            npc_traffic_2: sut.npc_free_driving() with:
                keep(it.npc_relative_position in [-20m..20m])
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == npc_lane)
                keep(it.npc_target_lane == npc_lane)
                keep(it.npc_duration == driving_duration)
                keep(it.ref_car == sut.car)
            
            # 中间车道NPC 3 (前方近距离)
            npc_traffic_3: sut.npc_free_driving() with:
                keep(it.npc_relative_position in [80m..120m])
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == npc_lane)
                keep(it.npc_target_lane == npc_lane)
                keep(it.npc_duration == driving_duration)
                keep(it.ref_car == sut.car)
            
            # 中间车道NPC 4 (前方远距离)
            npc_traffic_4: sut.npc_free_driving() with:
                keep(it.npc_relative_position in [180m..220m])
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == npc_lane)
                keep(it.npc_target_lane == npc_lane)
                keep(it.npc_duration == driving_duration)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.NextLaneExit_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "NextLaneExit_test_run"
    set additional_parameters.test_index = "auto_20251130_000002"
