import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$OSC2LIB/scenarios/crossing_VRU/vru_crossing/vru_crossing_pedestrian_no_wait_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.ghost_walk_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "ghost_walk_test_run")
    
    # 道路定义
    road: one_way_road
    
    # 车道参数
    ego_lane: int with:
        keep(it >= 1)

    npc_lane: int with:
        keep(it in [ego_lane - 1, ego_lane + 1])

    # 位置参数
    start_offset: length with:
        keep(it <= road.length - 150m)

    # 速度参数
    ego_start_speed: speed with:
        keep(default it in [30kph,40kph,50kph,60kph])

    # 距离参数
    rear_static_distance: length with:
        keep(default it in [15m..20m])

    front_static_distance: length with:
        keep(it == rear_static_distance + 10m)

    vru_distance: length with:
        keep(it == rear_static_distance + 5m)

    # VRU参数
    vru_direction: av_side with:
        keep(it == left => npc_lane == ego_lane - 1)
        keep(it == right => npc_lane == ego_lane + 1)

    # 时间参数
    crossing_time: time with:
        keep(it >= 3.5m / 5kph + 2s)

    # 行为配置
    keep(sut.car.ftx_driver.bypass_behavior.allow_opposite_left_side == true)

    # 日志输出
    on @set_up.start:
        call logger.log_info("Ego speed:          $(ego_start_speed)")
        call logger.log_info("Rear car distance:  $(rear_static_distance)")
        call logger.log_info("Front car distance: $(front_static_distance)")
        call logger.log_info("Ped. distance:      $(vru_distance)")
        call logger.log_info("Crossing time:      $(crossing_time)")

    do serial():
        set_up: parallel():
            # 自车：在单行道上自由驾驶
            ego_drive: sut.ego_free_drive_auto_gen_one_way_road() with:
                keep(it.gen_ego_speed_at_start == ego_start_speed)
                keep(it.ego_road_element == road)
                keep(it.gen_min_lanes == npc_lane)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.ego_start_offset == start_offset)
                keep(it.ego_driving_duration == crossing_time)

            # 行人：从侧方横穿道路
            vru_cross: sut.vru_crossing_pedestrian_no_wait() with:
                keep(it.gen_pedestrian_longitudinal_distance == start_offset + vru_distance)
                keep(it.gen_pedestrian_lateral_distance == (npc_lane - ego_lane)*3.5m)
                keep(it.gen_pedestrian_speed == 5kph)
                keep(it.gen_number_of_pedestrians == 1)
                keep(it.up_coming_car == sut.car)
                keep(it.move_from == vru_direction)
                keep(it.my_road == road)

            # 后车：静态车辆（位于自车后方）
            rear_static_car: sut.npc_free_driving() with:
                keep(it.npc_relative_position == rear_static_distance)
                keep(it.npc_initial_speed == 0kph)
                keep(it.npc_target_speed  == 0kph)
                keep(it.npc_initial_lane  == npc_lane)
                keep(it.npc_target_lane   == npc_lane)
                # keep(it.npc_vehicle_type  == car)
                keep(it.npc_duration      == crossing_time)
                keep(it.ref_car == sut.car)

            # 前车：静态车辆（位于自车前方）
            front_static_car: sut.npc_free_driving() with:
                keep(it.npc_relative_position == front_static_distance)
                keep(it.npc_initial_speed == 0kph)
                keep(it.npc_target_speed  == 0kph)
                keep(it.npc_initial_lane  == npc_lane)
                keep(it.npc_target_lane   == npc_lane)
                # keep(it.npc_vehicle_type  == suv)
                keep(it.npc_duration      == crossing_time)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.ghost_walk_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "ghost_walk_test_run"
    set additional_parameters.test_index = "auto_20251121_000008"