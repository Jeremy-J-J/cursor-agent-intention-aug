import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.StaticBlockApproach_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "StaticBlockApproach_test_run")
    
    # 道路定义
    my_road: one_way_road
    
    # 车道参数
    ego_lane: int with:
        keep(it >= 1)

    # 速度参数
    ego_start_speed: speed with:
        keep(it in [30kph..60kph])

    # 距离参数
    car_distance: length with:
        keep(it in [20m..60m])

    truck_distance: length with:
        keep(it == car_distance + 10m)

    # 时间参数
    duration_time: time with:
        keep(it in [6s..10s])

    # 行为配置
    keep(sut.car.ftx_driver.bypass_behavior.allow_opposite_left_side == true)

    # 日志输出
    on @set_up.start:
        call logger.log_info("Ego speed:            $(ego_start_speed)")
        call logger.log_info("Car distance:         $(car_distance)")
        call logger.log_info("Truck distance:       $(truck_distance)")
        call logger.log_info("Scenario duration:    $(duration_time)")

    do serial():
        set_up: parallel():
            # 自车：在单行道上自由驾驶
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_one_way_road() with:
                keep(it.gen_ego_speed_at_start == ego_start_speed)
                keep(it.ego_road_element == my_road)
                keep(it.gen_min_lanes == 1)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.ego_start_offset == my_road.length - truck_distance - 10m)
                keep(it.ego_driving_duration == duration_time)

            # 静态车辆：轿车（位于自车前方）
            npc_car_phase: sut.npc_free_driving() with:
                keep(it.npc_relative_position == car_distance)
                keep(it.npc_initial_speed == 0kph)
                keep(it.npc_target_speed  == 0kph)
                keep(it.npc_initial_lane  == ego_lane)
                keep(it.npc_target_lane   == ego_lane)
                keep(it.npc_duration      == duration_time)
                keep(it.ref_car == sut.car)

            # 静态车辆：卡车（位于自车前方，轿车之后）
            npc_truck_phase: sut.npc_free_driving() with:
                keep(it.npc_relative_position == truck_distance)
                keep(it.npc_initial_speed == 0kph)
                keep(it.npc_target_speed  == 0kph)
                keep(it.npc_initial_lane  == ego_lane)
                keep(it.npc_target_lane   == ego_lane)
                keep(it.npc_vehicle_type  == box_truck)
                keep(it.npc_duration      == duration_time)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.StaticBlockApproach_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "StaticBlockApproach_test_run"
    set additional_parameters.test_index = "auto_20251121_000007"