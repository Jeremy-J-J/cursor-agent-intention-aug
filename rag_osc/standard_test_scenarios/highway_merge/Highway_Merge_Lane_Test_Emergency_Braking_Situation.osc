# 场景: decel_then_merge_test_run
# 描述: 自车在汇入车道,前方同车道有较慢车辆,需要减速并寻找汇入时机
# 地图: M56_FTX_highway_prague.xodr (高速公路)

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_road_with_merging_lane_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$FTX/packages/maps/M56_FTX_highway_prague.xodr"

scenario sut.decel_then_merge_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "decel_then_merge_test_run")
    
    # 汇入车道
    my_road: road_with_merging_lane

    # 前方车辆相对位置
    front_relative_position: length with:
        keep(it in [20m..120m])

    # 自车车道
    ego_lane: int

    # 自车速度
    ego_speed: speed with:
        keep(it in [20kph..80kph])

    # 行驶持续时间
    driving_duration: time with:
        keep(it in [5s..15s])

    # NPC速度 (比自车慢)
    npc_speed: speed with:
        keep(it <= ego_speed)
    
    do serial():
        set_up: parallel():
            # 自车在汇入车道行驶
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_road_with_merging_lane() with:
                keep(it.gen_ego_speed_at_start == ego_speed)
                keep(it.ego_road_element == my_road)
                keep(it.gen_min_lanes == 2)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.ego_driving_duration == driving_duration)

            # 前方较慢的NPC车辆
            npc_driving_phase: sut.npc_free_driving() with:
                keep(it.npc_relative_position == front_relative_position)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_duration == driving_duration)
                keep(it.npc_initial_lane == ego_lane)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.decel_then_merge_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "decel_then_merge_test_run"
    set additional_parameters.test_index = "auto_20251106_075241"