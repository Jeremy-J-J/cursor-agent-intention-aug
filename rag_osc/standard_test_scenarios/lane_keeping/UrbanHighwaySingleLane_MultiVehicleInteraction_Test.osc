# 场景: ClusteredTraffic_test_run
# 描述: 密集交通场景，自车周围有多辆NPC车辆(前/后/左前/左后/右前/右后)
# 地图: M499_FTX_suburban.xodr (市郊)

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"
import "$PROJECT_DIR/standard_test_scenarios/_common/scenario_helpers.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.clustered_traffic_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "clustered_traffic_test_run")
    
    my_road: one_way_road
    
    # 自车车道
    ego_lane: int with:
        keep(it >= 2)
    
    # 自车初始速度
    ego_speed: speed with:
        keep(default it in [40kph, 60kph, 80kph])
    
    # 起始偏移
    start_offset: length with:
        keep(it <= my_road.length - 300m)
    
    # 场景持续时间
    duration_time: time with:
        keep(default it == 15s)
    
    # 同车道前/后方NPC间距
    npc_front_gap: length with:
        keep(default it in [20m..30m])
    
    npc_rear_gap: length with:
        keep(default it in [-30m..-20m])
    
    # 左侧车道前/后方NPC间距
    npc_left_front_gap: length with:
        keep(default it in [25m..40m])
    
    npc_left_rear_gap: length with:
        keep(default it in [-40m..-25m])
    
    # 右侧车道前/后方NPC间距
    npc_right_front_gap: length with:
        keep(default it in [25m..40m])
    
    npc_right_rear_gap: length with:
        keep(default it in [-40m..-25m])
    
    # NPC车辆速度
    npc_speed: speed with:
        keep(default it in [40kph..90kph])

    on @set_up.start:
        call logger.log_info("===== ClusteredTraffic场景参数 =====")
        call logger.log_info("自车初始速度:           $(ego_speed)")
        call logger.log_info("场景持续时间:           $(duration_time)")
        call logger.log_info("自车车道:               $(ego_lane)")
        call logger.log_info("同车道前/后间距:        $(npc_front_gap) / $(npc_rear_gap)")
        call logger.log_info("左侧车道前/后间距:      $(npc_left_front_gap) / $(npc_left_rear_gap)")
        call logger.log_info("右侧车道前/后间距:      $(npc_right_front_gap) / $(npc_right_rear_gap)")
        call logger.log_info("NPC速度:                $(npc_speed)")
    
    do serial():
        set_up: parallel():
            # 自车行驶阶段
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_one_way_road() with:
                keep(it.gen_ego_speed_at_start == ego_speed)
                keep(it.ego_road_element == my_road)
                keep(it.gen_min_lanes == 3)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.gen_ego_lane_at_end == ego_lane)
                keep(it.ego_start_offset == start_offset)
                keep(it.ego_driving_duration == duration_time)
            
            # 同车道前方NPC
            npc_front: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_front_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane)
                keep(it.npc_target_lane == ego_lane)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 同车道后方NPC
            npc_rear: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_rear_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane)
                keep(it.npc_target_lane == ego_lane)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 左侧车道前方NPC
            npc_left_front: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_left_front_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane - 1)
                keep(it.npc_target_lane == ego_lane - 1)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 左侧车道后方NPC
            npc_left_rear: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_left_rear_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane - 1)
                keep(it.npc_target_lane == ego_lane - 1)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 右侧车道前方NPC
            npc_right_front: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_right_front_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane + 1)
                keep(it.npc_target_lane == ego_lane + 1)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)
            
            # 右侧车道后方NPC
            npc_right_rear: sut.npc_free_driving() with:
                keep(it.npc_relative_position == npc_right_rear_gap)
                keep(it.npc_initial_speed == npc_speed)
                keep(it.npc_target_speed == npc_speed)
                keep(it.npc_initial_lane == ego_lane + 1)
                keep(it.npc_target_lane == ego_lane + 1)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.clustered_traffic_test_run()

extend test_additional_parameters:
    const test_index : string

extend test_config:
    set test_name = "clustered_traffic_test_run"
    set additional_parameters.test_index = "auto_20251126_000001"