# 测试场景: 阻塞车流
# 描述: 测试前方有停止卡车且后方有密集车流时的应对
# 场景: 三车道,自车以80kph在车道2行驶,前方50-80米处有停止卡车,后方有22辆60kph的密集车流

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$FTX/env/basic/behavioral_models/ftx/ftx_group_driver_model.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.block_stream_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "block_stream_test_run")
    
    # 测试道路
    my_road: one_way_road
    
    # 停止的卡车
    stopped_truck: vehicle
    keep(stopped_truck.vehicle_category == box_truck)
    
    # 自车车道
    ego_lane: int with:
        keep(default it == 2)
    
    # 起始偏移
    start_offset: length with:
        keep(it <= my_road.length - 400m)
    
    # 自车速度
    ego_speed: speed with:
        keep(default it == 80kph)
    
    # 卡车距离
    truck_distance: length with:
        keep(default it in [50m..80m])
    
    # 车流速度
    traffic_speed: speed with:
        keep(default it == 60kph)
    
    # 车流间距
    traffic_gap: length with:
        keep(default it == 30m)
    
    # 车流数量
    num_traffic_cars: int with:
        keep(default it == 22)
    
    # 测试持续时间
    duration_time: time with:
        keep(default it == 10s)
    
    # 车流驾驶员模型
    traffic_driver: ftx_group_driver_model with:
        keep(it.use_target_speed == true)
        keep(it.target_speed == traffic_speed)
    
    # 后方密集车流组
    traffic_stream_group: all_lanes_car_group with:
        keep(it.reference_car == sut.car)
        keep(it.cars.size() == num_traffic_cars)
        keep(it.reference_car_index == 0)
    
    for car in traffic_stream_group.cars:
        keep(car.initial_bm == traffic_driver)
        keep(car.color == blue)
        keep(car.ftx_driver.collision_avoidance_behavior.safety_distance_lon == traffic_gap)
    
    for params in traffic_stream_group.members_params:
        keep(params.initial_speed_percentage == 100)
        keep(params.min_initial_ttc in [1s..2s])
    
    keep(sut.car.ftx_driver.bypass_behavior.allow_opposite_left_side == true)
    
    do parallel(duration: duration_time):
        # 自车自由行驶
        ego_free_drive_phase: sut.ego_free_drive_auto_gen_one_way_road() with:
            keep(it.gen_ego_speed_at_start == ego_speed)
            keep(it.ego_road_element == my_road)
            keep(it.gen_min_lanes == 3)
            keep(it.gen_ego_lane_at_start == ego_lane)
            keep(it.gen_ego_lane_at_end == ego_lane)
            keep(it.ego_start_offset == self.start_offset)
            keep(it.ego_driving_duration == duration_time)
        
        # 前方停止的卡车
        truck_phase: sut.npc_free_driving() with:
            keep(it.npc_relative_position == truck_distance)
            keep(it.npc_initial_speed == 0kph)
            keep(it.npc_target_speed == 0kph)
            keep(it.npc_initial_lane == ego_lane)
            keep(it.npc_target_lane == ego_lane)
            keep(it.npc_vehicle_type == box_truck)
            keep(it.npc_duration == duration_time)
            keep(it.ref_car == sut.car)
        
        # 后方密集车流
        traffic_stream_group.group_drive()

extend top.main:
    do sut.block_stream_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "block_stream_test_run"
    set additional_parameters.test_index = "auto_20251130_000000"
