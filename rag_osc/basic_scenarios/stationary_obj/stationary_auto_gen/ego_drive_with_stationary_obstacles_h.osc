##############################################################################
# Header file for ego_drive_with_stationary_obstacles scenario
##############################################################################

# Import base packages
# Define the scenario
scenario sut.ego_drive_with_stationary_obstacles inherits stationary_objects_family_base:
    
    # Ego vehicle - to be provided as input variable

    stationary_object_positon: msp_position
    gen_stationary_obect_kind: object_kind
    gen_stationary_vehicle_category: vehicle_category
    object_relative_lane_offset: int

    ref_car: vehicle
    
    # Stationary obstacle groups
    stationary_obstacle_group_1: plain_object_group
    stationary_obstacle_group_2: plain_object_group
    

    # Positioning parameters
    obstacle_lon_offset: length
    obstacle_lat_offset: length
    #obstacle_2_lon_offset: length
    #obstacle_2_lat_offset: length
    
    # Ego starting parameters
    #gen_ego_speed_at_start: speed
    #gen_ego_speed_at_end: speed
    #gen_ego_lane_at_start: integer
    
    # Generated parameters
    gen_ego_lane_width: length
    max_object_dimension: length
    
    # Rotation parameters for obstacles
    #gen_stationary_obstacle_group_1_min_yaw: angle
    #gen_stationary_obstacle_group_1_max_yaw: angle
    #gen_stationary_obstacle_group_2_min_yaw: angle
    #gen_stationary_obstacle_group_2_max_yaw: angle
    
    # Duration parameters
    #gen_duration_at_essence_generic: duration
    #post_phase_duration: duration
    