scenario sut.ego_free_drive_auto_gen_road_with_opposite inherits ego_free_drive_auto_gen_base:
    keep(default scenario_str == "ego_free_drive_auto_gen_one_way_road")
    # ego_road_element: roads_follow_in_junction

    ego_road_element: road_with_opposite
    keep(ego_road_element.main.one_way_road.min_lanes >=gen_min_lanes)
    keep(ego_road_element.main.one_way_road.max_lanes <=gen_max_lanes)

    ego_start_offset: length
    keep(ego_start_offset >= 0m)
    keep(ego_start_offset <= ego_road_element.length - 20m)
    #keep(ego_road_element.internal_road.direction == left)
