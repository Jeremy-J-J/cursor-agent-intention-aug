# Auto-generated scenario header for highway_exit

scenario sut.ego_free_drive_auto_gen_highway_exit inherits ego_free_drive_auto_gen_base:
    keep(default scenario_str == "ego_free_drive_auto_gen_highway_exit")
    # ego_road_element: roads_follow_in_junction

    # ego_road_element: roads_follow_in_junction_with_sign
    #keep(ego_road_element.internal_road.direction == left)
    #keep(ego_road_element.road_with_sign.sign_type == stop)


    # ego_road_element: road_curvature with:
    #      #keep(it.min_radius >= 50m)
    #     keep(it.max_radius < 200m and it.length > 3m)
    # ego_road_element:slope_section with:
    #     keep(it.max_slope > 2deg and it.direction == uphill_slope)

    high_way: highway with:
        keep(default it.lanes in [gen_min_lanes..gen_max_lanes])

    connection: internal_road

    ego_road_element: highway_exit
        
    ego_start_offset: length
    keep(ego_start_offset >= 0m)
    keep(ego_start_offset <= high_way.length - 20m)


    duration_along_highway: time with:
        keep(duration_along_highway <= ego_driving_duration)
    
    # Additional highway-exit specific keeps can be added here

scenario sut.ego_free_drive_auto_gen_highway_exit_test inherits ego_free_drive_auto_gen_test:
    keep(default scenario_str == "ego_free_drive_auto_gen_highway_exit_test")
