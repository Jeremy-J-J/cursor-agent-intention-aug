# Auto-generated scenario header for merge_from_entry

scenario sut.ego_free_drive_auto_gen_merge_from_entry inherits ego_free_drive_auto_gen_base:
    keep(default scenario_str == "ego_free_drive_auto_gen_merge_from_entry")
    # ego_road_element: roads_follow_in_junction

    # ego_road_element: roads_follow_in_junction_with_sign
    #keep(ego_road_element.internal_road.direction == left)
    #keep(ego_road_element.road_with_sign.sign_type == stop)


    # ego_road_element: road_curvature with:
    #      #keep(it.min_radius >= 50m)
    #     keep(it.max_radius < 200m and it.length > 3m)
    # ego_road_element:slope_section with:
    #     keep(it.max_slope > 2deg and it.direction == uphill_slope)

    ego_road_element: merge_from_entry with:
        keep(default it.out_road.max_lanes == gen_max_lanes)
        keep(default it.out_road.min_lanes == gen_min_lanes)
        
    ego_start_offset: length
    keep(ego_start_offset >= 0m)
    keep(ego_start_offset <= ego_road_element.in_road.length - 20m)
    
    # merge-specific keeps or parameters can be added here
   
    
    
scenario sut.ego_free_drive_auto_gen_merge_from_entry_test inherits ego_free_drive_auto_gen_test:
