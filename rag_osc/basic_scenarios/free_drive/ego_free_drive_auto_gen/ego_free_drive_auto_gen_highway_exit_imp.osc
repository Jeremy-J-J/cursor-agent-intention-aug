extend sut.ego_free_drive_auto_gen_highway_exit:

    on @phase_essence.start: 
        call logger.log_info("logging from highway_exit scenario")
        call logger.log_info("$(ego_road_element)")
        call logger.log_info("gen_ego_lane_at_start : $(gen_ego_lane_at_start)")
        call logger.log_info("gen_ego_lane_at_end : $(gen_ego_lane_at_end)")
        call logger.log_info("distance_offset : $(distance_offset)")
        call logger.log_info("vehicle_category: $(sut.car.vehicle_category)")
        call logger.log_info("current_planned_road: $(sut.car.current_planned_road)")
        call logger.log_info("state_speed: $(sut.car.state.speed)")
        call logger.log_info("gen_ego_lane_at_start: $(gen_ego_lane_at_start)")
        call logger.log_info("ego_start_offset: $(ego_start_offset)")
        call logger.log_info("state_lane_index: $(sut.car.state.msp_pos.lane_position.lane.index_in_road)")
        call logger.log_info("road_position_lane_size: $(sut.car.state.msp_pos.road_position.road.lanes.size())")
        # call logger.log_info("state_lane_index_adjused: $(sut.car.state.msp_pos.lane_position.lane.index_in_road-sut.car.state.msp_pos.road_position.road.lanes.size()+1)")

    # ego_road_element: highway_exit
    do phase_essence: serial():

        drive_ego_at_essence_phase_1: sut.car.drive() with:
            # Apply collision avoidance if enabled
            avoid_collisions(default avoid_collisions)
            # keep(if avoid_collisions then apply_collision_avoidance())
            
            # Set initial speed at start
            intent_assist_ego_speed_at_essence: speed(gen_ego_speed_at_start, at: start, run_mode: best_effort)
            
            # Adjust speed at end
            intent_assist_ego_speed_at_end: speed(gen_ego_speed_at_end, at: end, run_mode: best_effort)

            # set inital lane at start
            intent_assist_ego_lane_at_essence_start: lane(gen_ego_lane_at_start, at: start, run_mode: best_effort)

            # adjust lane at end
            intent_assist_ego_lane_at_essence_end: lane(gen_ego_lane_at_end, at: end, run_mode: best_effort)

            # Drive along the specified road element type

            intent_assist_ego_along_at_essence: along(high_way,
                    run_mode: best_effort, 
                    at: start, 
                    start_offset: ego_start_offset)
                
            intent_assist_ego_along_at_essence_end: along(connection,
                    run_mode: best_effort, 
                    at: end)

            intent_assist_ego_duration_at_essence: duration(duration_along_highway, run_mode: best_effort)


        drive_ego_at_essence_phase_2: sut.car.drive() with:
            # Apply collision avoidance if enabled
            avoid_collisions(default avoid_collisions)
            # keep(if avoid_collisions then apply_collision_avoidance())
            
            # Set initial speed at start
            # intent_assist_ego_speed_at_essence: speed(gen_ego_speed_at_start, at: start, run_mode: best_effort)
            
            # Adjust speed at end
            # intent_assist_ego_speed_at_end: speed(gen_ego_speed_at_end, at: end, run_mode: best_effort)

            # set inital lane at start
            # intent_assist_ego_lane_at_essence_start: lane(gen_ego_lane_at_start, at: start, run_mode: best_effort)

            # adjust lane at end
            # intent_assist_ego_lane_at_essence_end: lane(gen_ego_lane_at_end, at: end, run_mode: best_effort)

            # Drive along the specified road element type

            intent_assist_ego_along_at_essence_2: along(connection,
                    run_mode: best_effort, 
                    at: start)

            intent_assist_ego_along_at_essence_end_2: along(ego_road_element,
                    run_mode: best_effort, 
                    at: end)

            # Matintain duration
            intent_assist_ego_duration_at_essence_2: duration(ego_driving_duration - duration_along_highway,
                 run_mode: best_effort)


# ego_free_drive_auto_gen_test scenario implementation
# scenario invokes serially ego warm up, ego_free_drive_auto_gen and then the post scenarios
extend sut.ego_free_drive_auto_gen_highway_exit_test:

    do phase_test: serial():

        # invoke the default base ego warm up scenario for the free_drive family
        phase_ego_warm_up: free_drive_family_base_ego_warm_up()

        # invoke ego_free_drive_auto_gen scenario
        phase_scenario: ego_free_drive_auto_gen_highway_exit()

        # invoke the default base post scenario for the free_drive family
        phase_post: free_drive_family_base_post()
