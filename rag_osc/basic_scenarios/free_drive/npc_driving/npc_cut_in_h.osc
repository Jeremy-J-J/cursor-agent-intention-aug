# NPC cut-out scenario

scenario sut.npc_cut_in inherits npc_driving_behavior_base:
    keep(default scenario_str == "npc_cut_in")

    # Override default parameters for acceleration/deceleration behavior
    npc_car: vehicle
    ref_car: vehicle
    
    # Relative position parameters
    npc_relative_position: length
    keep(default npc_relative_position in [-100m..100m])
    
    # Speed parameters
    # npc_initial_speed: speed
    # keep(default npc_initial_speed in [0..120]kph)

    direction: av_side
    keep(npc_initial_lane > npc_target_lane => direction == left)
    keep(npc_initial_lane < npc_target_lane => direction == right)
    
    npc_cut_in_speed: speed
    keep(default npc_cut_in_speed in [0..120]kph)
    
    # Timing parameters
    npc_cut_in_start_time: time
    keep(default npc_cut_in_start_time in [0s..30s])
    
    npc_cut_in_duration: time
    keep(default npc_cut_in_duration in [1s..10s])


scenario sut.npc_cut_in_test inherits npc_driving_behavior_test:
    keep(default scenario_str == "npc_cut_in_test")
