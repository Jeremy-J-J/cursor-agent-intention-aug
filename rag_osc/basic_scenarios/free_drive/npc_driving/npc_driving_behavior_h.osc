# Base scenario for NPC vehicle driving behavior

scenario sut.npc_driving_behavior_base inherits free_drive_family_base:
    keep(default scenario_str == "npc_driving_behavior_base")

    # Road parameters
    gen_min_lanes: int 
    keep(gen_min_lanes >= 1)

    gen_max_lanes: int
    # keep(default gen_max_lanes in ftlx_lib_base_config.default_max_num_of_lane_at_road_element)
  
    # NPC vehicle parameters
    npc_vehicle_type: vehicle_category

    # keep(default npc_vehicle_type in [car, box_truck, full_trailer_truck, bus, motorcycle])
    
    # Relative position parameters
    npc_relative_position_x: length
    keep(default npc_relative_position_x in [-100m..100m])
    
    npc_relative_position_y: length
    keep(default npc_relative_position_y in [-50m..50m])
    
    npc_relative_position_z: length
    keep(default npc_relative_position_z in [0m..10m])
    
    # Speed parameters
    npc_initial_speed: speed
    keep(default npc_initial_speed in [0..120]kph)
    
    npc_target_speed: speed
    keep(default npc_target_speed in [0..120]kph)
    
    # Direction parameters
    npc_driving_direction: string
    keep(default npc_driving_direction in ["same_direction", "opposite_direction", "perpendicular"])
    
    # Timing parameters
    npc_start_time: time
    keep(default npc_start_time in [0s..30s])
    
    npc_duration: time
    keep(default npc_duration in [5s..60s])

    # Behavior parameters
    npc_behavior_type: string
    keep(default npc_behavior_type in ["normal", "aggressive", "cautious"])
    
    # Distance parameters
    npc_distance_to_ego: length
    keep(default npc_distance_to_ego in [10m..200m])
    
    # Lane parameters
    npc_initial_lane: int
    keep(default npc_initial_lane in [gen_min_lanes..gen_max_lanes])
    
    npc_target_lane: int
    keep(default npc_target_lane in [gen_min_lanes..gen_max_lanes])

scenario sut.npc_driving_behavior_test inherits free_drive_family_base_test:
    keep(default scenario_str == "npc_driving_behavior_test")
