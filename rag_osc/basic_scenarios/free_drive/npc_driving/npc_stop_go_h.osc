# Base scenario for NPC vehicle driving behavior

scenario sut.npc_stop_go inherits free_drive_family_base:
    keep(default scenario_str == "npc_driving_behavior_base")
    npc_car: vehicle
    ref_car: vehicle

    # road_element: road_with_opposite
    
    # Relative position parameters
    npc_relative_position: length
    keep(default npc_relative_position in [-100m..100m])
    
    # Speed parameters
    npc_initial_speed: speed
    keep(default npc_initial_speed in [0..120]kph)
    
    npc_target_speed: speed
    keep(default npc_target_speed in [0..120]kph)
    
    # Direction parameters
    # npc_driving_direction: string
    # keep(default npc_driving_direction in ["same_direction", "opposite_direction", "perpendicular"])
    
    # Timing parameters
    npc_stop_start_time: time
    keep(default npc_stop_start_time in [0s..30s])
    
    npc_stop_duration: time
    keep(default npc_stop_duration in [5s..60s])

    # Behavior parameters
    # npc_behavior_type: string
    # keep(default npc_behavior_type in ["normal", "aggressive", "cautious"])
    
    # # Distance parameters
    # npc_distance_to_ego: length
    # keep(default npc_distance_to_ego in [10m..500m])

    # npc_start_offset: length
    # keep(npc_start_offset in [ref_car_offset+npc_relative_position_x-10m..ref_car_offset+npc_relative_position_x+10m] )
    
    # Lane parameters
    # npc_initial_lane: int
    # keep(default npc_initial_lane in [gen_min_lanes..gen_max_lanes])
    
    # npc_target_lane: int
    # keep(default npc_target_lane in [gen_min_lanes..gen_max_lanes])

scenario sut.npc_stop_go_test inherits free_drive_family_base_test:
    keep(default scenario_str == "npc_free_driving_oppsite_test")
