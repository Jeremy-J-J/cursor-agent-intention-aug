# Base scenario for NPC vehicle driving behavior

scenario sut.npc_free_driving inherits npc_driving_behavior_base:
    keep(default scenario_str == "npc_free_driving")

    # npc_vehicle_type: string
    # keep(default npc_vehicle_type in ["car", "truck", "bus", "motorcycle"])

    npc_car: vehicle with:
        keep(npc_car.vehicle_category == npc_vehicle_type)
    ref_car: vehicle

    # npc.car.vehicle_category

    # # Road parameters
    # gen_min_lanes: int 
    # keep(gen_min_lanes >= 1)

    # gen_max_lanes: int
    # keep(default gen_max_lanes in ftlx_lib_base_config.default_max_num_of_lane_at_road_element)
  
    # # NPC vehicle parameters

    
    # Relative position parameters
    npc_relative_position: length
    keep(default npc_relative_position in [-100m..100m])
    

scenario sut.npc_free_driving_test inherits npc_driving_behavior_test:
    keep(default scenario_str == "npc_driving_behavior_test")
