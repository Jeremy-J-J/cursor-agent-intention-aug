extend sut.npc_free_driving:
    on @phase_essence.start: 
        call logger.log_info("Starting NPC acceleration/deceleration scenario")
        call logger.log_info("NPC will accelerate/decelerate from $(npc_initial_speed) to $(npc_target_speed) over $(npc_duration) seconds")

    # on @top.clk:
    #     call logger.log_info("npc_initial_lane: $(npc_initial_lane)")
    #     call logger.log_info("npc_target_lane: $(npc_target_lane)")

    do phase_essence: serial():
        # Create NPC vehicle for acceleration/deceleration behavior
        npc_vehicle: npc_car.drive() with:
            # Position relative to ego
            position(npc_relative_position, ahead_of: ref_car, at: start)
            
            speed(npc_initial_speed,at: start)
            # keep_speed(, run_mode: best_effort)
            speed(npc_target_speed, at: end)
            lane(npc_initial_lane, at: start)
            lane(npc_target_lane, at: end)
            
            # Lane position
            #lane(0, same_as: ref_car, at:start)

            duration(npc_duration)

    # keep()
    
