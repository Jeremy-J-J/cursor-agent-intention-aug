extend sut.npc_stop_go:

    on @phase_essence.start: 
        call logger.log_info("Starting NPC stop-and-go scenario")

    do phase_essence: serial():
        # Create NPC vehicle for stop-and-go behavior
        npc_vehicle_setup: npc_car.drive() with:
            # Position relative to ego
            position(npc_relative_position, ahead_of: ref_car, at: start)
            
            # Initial speed
            speed(npc_initial_speed, at:start)
            keep_speed()
            
            # Lane position
            lane(0, same_as: ref_car, at: start)

            duration(npc_stop_start_time)

        npc_stop_action: npc_car.drive() with:
            change_speed(-[10..20]kph)
            keep_lane()
            duration(npc_stop_duration)

        npc_resume_action: npc_car.drive() with:
            change_speed([10..20]kph)
            keep_lane()
            duration(npc_stop_duration)
        
        npc_finnal: npc_car.drive() with:
            keep_speed()
            keep_lane()



extend sut.npc_stop_go_test:

    do phase_test: serial():

        # Invoke the default base ego warm up scenario for the free_drive family
        phase_ego_warm_up: free_drive_family_base_ego_warm_up()

        # Invoke npc_stop_go scenario
        phase_scenario: npc_stop_go()

        # Invoke the default base post scenario for the free_drive family
        phase_post: free_drive_family_base_post()
