extend sut.npc_cut_in:

    on @phase_essence.start: 
        call logger.log_info("Starting NPC cut-in scenario")
        call logger.log_info("NPC will cut in from lane $(npc_initial_lane) to lane $(npc_target_lane)")

    do phase_essence: serial():
        # Create NPC vehicle for cut-in behavior
        npc_vehicle: npc_car.drive() with:
            # Position relative to ego
            position(npc_relative_position, ahead_of: ref_car, at: start)
            
            # Initial speed
            speed(npc_initial_speed)
            
            # Lane position
            lane(npc_initial_lane, at: start)
            # lane(right_of: ref_car, at: start)

            duration(npc_cut_in_start_time)

        # Change NPC vehicle lane to cut in front of ego
        npc_cut_in_action: npc_car.drive() with:
            change_lane(side: direction)
            keep_speed()
            #keep_lane(0, sa)
            #lane(same_as: ref_car)
            # change_lane(1, side: left)
            #speed(npc_target_speed)
            duration(npc_cut_in_duration)

        # Change NPC vehicle lane to cut in front of ego
        npc_cut_in_finish: npc_car.drive() with:
            #change_lane(1)
            keep_lane()
            keep_speed()
            # speed(npc_target_speed)
            duration(npc_duration-npc_cut_in_start_time-npc_cut_in_duration)


extend sut.npc_cut_in_test:

    do phase_test: serial():

        # Invoke the default base ego warm up scenario for the free_drive family
        phase_ego_warm_up: free_drive_family_base_ego_warm_up()

        # Invoke npc_cut_in scenario
        phase_scenario: npc_cut_in()

        # Invoke the default base post scenario for the free_drive family
        phase_post: free_drive_family_base_post()
