# Implementation file for VRU crossing base scenario

extend sut.vru_crossing_base_ego_warm_up:
 
    do phase_ego_warm_up: parallel(overlap: equal):
        drive_ego_at_ego_warm_up: sut.car.drive() with:
            intent_assist_ego_keep_lane_at_ego_warm_up: keep_lane(run_mode: best_effort)        
    with:
        intent_warm_up_duration: duration(gen_duration_at_ego_warm_up, tolerance: gen_duration_tolerance_at_ego_warm_up)
     
extend sut.vru_crossing_base_post:  
    drive_road: one_way_road 
     
    do phase_post: parallel(overlap: equal):
        drive_ego_at_post: sut.car.drive() with:
            intent_assist_ego_keep_lane_at_post: keep_lane(run_mode: best_effort)
            intent_assist_ego_keep_speed_at_post: keep_speed(run_mode: best_effort)
    with: 
        intent_post_duration: duration(gen_duration_at_post, tolerance: gen_duration_tolerance_at_post)