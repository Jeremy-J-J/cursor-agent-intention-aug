# Instance scenario for cyclist crossing based on vru_crossing_base
# This scenario focuses on cyclist crossing with configurable parameters

scenario sut.vru_crossing_cyclist inherits vru_crossing_base:
    keep(default scenario_str == "vru_crossing_cyclist")
    
    # Override to have only cyclists in this instance
    keep(gen_number_of_pedestrians == 0)
    keep(gen_number_of_cyclists in [1..5])
    
    # Specific parameters for cyclist crossing
    gen_cyclist_crossing_direction: angle
    keep(default gen_cyclist_crossing_direction in [70..110]degree or 
         default gen_cyclist_crossing_direction in [250..290]degree)
         
    # Position relative to ego vehicle
    gen_cyclist_lateral_distance: length
    keep(default gen_cyclist_lateral_distance in [5..20]m)
    
    gen_cyclist_longitudinal_distance: length
    keep(default gen_cyclist_longitudinal_distance in [10..50]m)
    
    # Timing of crossing
    gen_cyclist_crossing_time: time
    keep(default gen_cyclist_crossing_time in [2..8]s)

# Main scenario for cyclist crossing
scenario sut.vru_crossing_cyclist_main inherits vru_crossing_base_main:
    keep(default scenario_str == "vru_crossing_cyclist_main")

# Ego warm-up scenario for cyclist crossing
scenario sut.vru_crossing_cyclist_ego_warm_up inherits vru_crossing_base_ego_warm_up:
    keep(default scenario_str == "vru_crossing_cyclist_ego_warm_up")
    keep(gen_number_of_pedestrians == 0)

# Post scenario for cyclist crossing
scenario sut.vru_crossing_cyclist_post inherits vru_crossing_base_post:
    keep(default scenario_str == "vru_crossing_cyclist_post")
    keep(gen_number_of_pedestrians == 0)