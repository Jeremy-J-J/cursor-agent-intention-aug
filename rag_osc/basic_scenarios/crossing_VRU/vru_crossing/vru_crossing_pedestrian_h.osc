# Instance scenario for pedestrian crossing based on vru_crossing_base
# This scenario focuses on pedestrian crossing with configurable parameters

scenario sut.vru_crossing_pedestrian inherits vru_crossing_base:
    keep(default scenario_str == "vru_crossing_pedestrian")
    
    up_coming_car: vehicle
    # Override to have only pedestrians in this instance
    keep(gen_number_of_pedestrians in [1..5])
    # keep(gen_number_of_cyclists == 1)
    
    # Specific parameters for pedestrian crossing
    gen_pedestrian_crossing_direction: angle
    keep(gen_pedestrian_crossing_direction in [70..110]degree or 
        gen_pedestrian_crossing_direction in [250..290]degree)
         
    # Position relative to ego vehicle
    gen_pedestrian_lateral_distance: length
    keep(default gen_pedestrian_lateral_distance in [5..20]m)
    
    gen_pedestrian_longitudinal_distance: length
    keep(default gen_pedestrian_longitudinal_distance in [10..50]m)
    
    # Timing of crossing
    gen_pedestrian_crossing_time: time
    keep(default gen_pedestrian_crossing_time in [2..8]s)

    junction: roads_follow_in_junction

# Main scenario for pedestrian crossing
scenario sut.vru_crossing_pedestrian_main inherits vru_crossing_base_main:
    keep(default scenario_str == "vru_crossing_pedestrian_main")

